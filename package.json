{
  "name": "svelte-supabase-auth-template",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal Svelte 5 + Supabase Auth starter with Google OAuth, health check, and /me API integration. Pairs with cf-hono-supabase-api-template.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "init": "node scripts/init-from-template.mjs",
    "build": "vite build",
    "ci": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,js,svelte,json,md,css,html,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,svelte,json,md,css,html,yml,yaml}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-templates/svelte-supabase-auth-template.git"
  },
  "homepage": "https://github.com/open-templates/svelte-supabase-auth-template#readme",
  "bugs": {
    "url": "https://github.com/open-templates/svelte-supabase-auth-template/issues"
  },
  "keywords": [
    "svelte-supabase-auth-template",
    "supabase",
    "oauth",
    "google",
    "svelte",
    "vite",
    "cloudflare-pages",
    "bun"
  ],
  "author": {
    "name": "@xarlizard",
    "email": "38315638+xarlizard@users.noreply.github.com",
    "url": "https://github.com/xarlizard"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "bun@1.2.15",
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "svelte": "^5.39.6",
    "svelte-spa-router": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "eslint-plugin-svelte": "^3.11.0",
    "globals": "^16.5.0",
    "postcss": "^8.5.14",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte-eslint-parser": "^1.3.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.0"
  }
}
